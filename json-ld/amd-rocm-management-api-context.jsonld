    "temperature": "rocm:temperature",
    "fanSpeed": "rocm:fanSpeed",
    "powerDraw": "rocm:powerDraw",
    "eccErrors": "rocm:eccErrors",
    "DevicePerformance": "rocm:DevicePerformance",
