{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credits",
  "description": "GPU credit balance and usage.",
  "type": "object",
  "properties": {
    "balance": {
      "type": "number"
    },
    "used": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}